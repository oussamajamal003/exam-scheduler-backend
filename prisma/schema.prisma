generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  USER
}

model Center {
  id       Int     @id @default(autoincrement())
  name     String  @db.VarChar(100)
  location String? @db.VarChar(150)
  rooms    Room[]

  @@map("centers")
}

model CourseOffering {
  id               Int            @id @default(autoincrement())
  courseId         Int            @map("course_id")
  semesterId       Int            @map("semester_id")
  section          String?        @db.VarChar(20)
  expectedStudents Int?           @default(0) @map("expected_students")
  course           Course         @relation(fields: [courseId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  semester         Semester       @relation(fields: [semesterId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  exams            Exam[]
  registrations    Registration[]

  @@map("course_offerings")
}

model Course {
  id              Int              @id @default(autoincrement())
  code            String           @unique @db.VarChar(20)
  title           String           @db.VarChar(150)
  creditHours     Int?             @map("credit_hours")
  courseOfferings CourseOffering[]

  @@map("courses")
}

model ExamRoomAssignment {
  id     Int  @id @default(autoincrement())
  examId Int  @map("exam_id")
  roomId Int  @map("room_id")
  exam   Exam @relation(fields: [examId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  room   Room @relation(fields: [roomId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("exam_room_assignments")
}

model Exam {
  id                    Int                    @id @default(autoincrement())
  courseOfferingId      Int                    @map("course_offering_id")
  timeSlotId            Int?                   @map("time_slot_id")
  status                String?                @default("draft") @db.VarChar(30)
  examRoomAssignments   ExamRoomAssignment[]
  courseOffering        CourseOffering         @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  timeSlot              TimeSlot?              @relation(fields: [timeSlotId], references: [id], onUpdate: NoAction)
  supervisorAssignments SupervisorAssignment[]

  @@map("exams")
}

model Registration {
  id               Int            @id @default(autoincrement())
  studentId        Int            @map("student_id")
  courseOfferingId Int            @map("course_offering_id")
  courseOffering   CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  student          Student        @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([studentId, courseOfferingId])
  @@map("registrations")
}

model Room {
  id                  Int                  @id @default(autoincrement())
  centerId            Int                  @map("center_id")
  roomName            String               @map("room_name") @db.VarChar(50)
  capacity            Int
  isAvailable         Boolean?             @default(true) @map("is_available")
  examRoomAssignments ExamRoomAssignment[]
  center              Center               @relation(fields: [centerId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("rooms")
}

model Semester {
  id              Int              @id @default(autoincrement())
  name            String           @db.VarChar(100)
  startDate       DateTime?        @map("start_date") @db.Date
  endDate         DateTime?        @map("end_date") @db.Date
  courseOfferings CourseOffering[]

  @@map("semesters")
}

model Student {
  id            Int            @id @default(autoincrement())
  universityId  String         @unique @map("university_id") @db.VarChar(30)
  fullName      String         @map("full_name") @db.VarChar(150)
  email         String?        @unique @db.VarChar(120)
  registrations Registration[]

  @@map("students")
}

model SupervisorAssignment {
  id           Int        @id @default(autoincrement())
  examId       Int        @map("exam_id")
  supervisorId Int        @map("supervisor_id")
  exam         Exam       @relation(fields: [examId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  supervisor   Supervisor @relation(fields: [supervisorId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("supervisor_assignments")
}

model Supervisor {
  id                    Int                    @id @default(autoincrement())
  fullName              String                 @map("full_name") @db.VarChar(150)
  email                 String?                @unique @db.VarChar(120)
  maxExamsPerDay        Int?                   @default(2) @map("max_exams_per_day")
  supervisorAssignments SupervisorAssignment[]

  @@map("supervisors")
}

model TimeSlot {
  id        Int      @id @default(autoincrement())
  examDate  DateTime @map("exam_date") @db.Date
  startTime DateTime @map("start_time") @db.Time(6)
  endTime   DateTime @map("end_time") @db.Time(6)
  exams     Exam[]

  @@map("time_slots")
}
