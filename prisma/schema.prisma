generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------
// ENUMS
// -----------------------------------
enum Role {
  TECH_ADMIN
  SCHEDULING_ADMIN
  SUPERVISOR
  STUDENT
}

enum ExamStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ConflictType {
  STUDENT_OVERLAP
  SUPERVISOR_DOUBLE_BOOKED
  ROOM_OVERCAPACITY
  RESOURCE_UNAVAILABLE
  TIME_CONSTRAINT_VIOLATION
}

// -----------------------------------
// USER SYSTEM
// -----------------------------------
model User {
  id         String      @id @default(uuid())
  name       String
  email      String      @unique
  password   String
  role       Role        @default(STUDENT)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  
  student    Student?
  supervisor Supervisor?

  @@map("users")
}

model Student {
  id           String       @id @default(uuid())
  userId       String       @unique
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId    String?
  program      Program?     @relation(fields: [programId], references: [id], onDelete: SetNull)
  universityId String       @unique
  
  registrations Registration[]

  @@map("students")
}

model Supervisor {
  id          String           @id @default(uuid())
  userId      String           @unique
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  centerId    String
  center      Center           @relation(fields: [centerId], references: [id], onDelete: Restrict)
  
  assignments ExamAssignment[]

  @@map("supervisors")
}

// -----------------------------------
// MINI SIS (ACADEMIC DATA)
// -----------------------------------
model Program {
  id        String    @id @default(uuid())
  name      String
  code      String    @unique
  
  students  Student[]
  courses   Course[]

  @@map("programs")
}

model Semester {
  id              String           @id @default(uuid())
  name            String           // e.g., "Fall 2026"
  startDate       DateTime
  endDate         DateTime
  
  courseOfferings CourseOffering[]

  @@map("semesters")
}

model Course {
  id              String           @id @default(uuid())
  code            String           @unique
  title           String
  programId       String?
  program         Program?         @relation(fields: [programId], references: [id], onDelete: SetNull)
  
  courseOfferings CourseOffering[]

  @@map("courses")
}

model CourseOffering {
  id               String         @id @default(uuid())
  courseId         String
  course           Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  semesterId       String
  semester         Semester       @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  section          String?
  expectedStudents Int            @default(0)
  
  registrations    Registration[]
  exams            Exam[]

  // A specific course section should only occur once per semester
  @@unique([courseId, semesterId, section])
  @@index([courseId])
  @@index([semesterId])
  @@map("course_offerings")
}

model Registration {
  id               String         @id @default(uuid())
  studentId        String
  student          Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseOfferingId String
  courseOffering   CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)

  // Prevent duplicate enrollment for the exact same offering
  @@unique([studentId, courseOfferingId])
  @@index([studentId])
  @@index([courseOfferingId])
  @@map("registrations")
}

// -----------------------------------
// RESOURCES
// -----------------------------------
model Center {
  id          String       @id @default(uuid())
  name        String       @unique
  location    String?
  
  rooms       Room[]
  supervisors Supervisor[]

  @@map("centers")
}

model Room {
  id          String           @id @default(uuid())
  centerId    String
  center      Center           @relation(fields: [centerId], references: [id], onDelete: Cascade)
  name        String
  capacity    Int
  
  assignments ExamAssignment[]

  // Room names must be unique within a center
  @@unique([centerId, name])
  @@map("rooms")
}

model TimeSlot {
  id          String           @id @default(uuid())
  startTime   DateTime
  endTime     DateTime
  
  assignments ExamAssignment[]

  @@map("time_slots")
}

// -----------------------------------
// EXAMS
// -----------------------------------
model Exam {
  id               String           @id @default(uuid())
  courseOfferingId String
  courseOffering   CourseOffering   @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  status           ExamStatus       @default(DRAFT)
  duration         Int?             // Duration in minutes
  
  assignments      ExamAssignment[]

  @@index([courseOfferingId])
  @@map("exams")
}

// -----------------------------------
// SCHEDULING CORE
// -----------------------------------
model Schedule {
  id          String           @id @default(uuid())
  name        String
  isFinal     Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  
  assignments ExamAssignment[]
  conflicts   Conflict[]

  @@map("schedules")
}

model ExamAssignment {
  id           String     @id @default(uuid())
  scheduleId   String
  schedule     Schedule   @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  
  examId       String
  exam         Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  
  roomId       String
  room         Room       @relation(fields: [roomId], references: [id], onDelete: Restrict)
  
  supervisorId String
  supervisor   Supervisor @relation(fields: [supervisorId], references: [id], onDelete: Restrict)
  
  timeSlotId   String
  timeSlot     TimeSlot   @relation(fields: [timeSlotId], references: [id], onDelete: Restrict)

  // Prevents algorithm from generating duplicate identical assignments for the same schedule
  @@unique([scheduleId, examId, roomId, supervisorId, timeSlotId])
  @@index([scheduleId])
  @@index([examId])
  @@index([roomId])
  @@map("exam_assignments")
}

// -----------------------------------
// CONFLICT SYSTEM
// -----------------------------------
model Conflict {
  id          String       @id @default(uuid())
  scheduleId  String
  schedule    Schedule     @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  
  type        ConflictType
  description String
  resolved    Boolean      @default(false)
  createdAt   DateTime     @default(now())

  @@index([scheduleId])
  @@map("conflicts")
}




// Mini SIS → (Students, Courses, Enrollments)
//       ↓
// Scheduling → (Exams, TimeSlots, Rooms, Supervisors)
//         ↓
// Execution → (Schedule, Assignments, Conflicts)